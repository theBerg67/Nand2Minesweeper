/** 
Function for drawing the selector 
Separate enigma from cells/bitmaps
*/
function void selectorDraw(int x, int y, int yo) {
	var int xPos; 
	var int yPos; 
	let xPos=(x*16);
	let yPos=((y)*16)+yo;
	// top 
	do Screen.drawRectangle(xPos, yPos, xPos+15, yPos+3);
	// bottom 
	do Screen.drawRectangle(xPos, yPos+13, xPos+15, yPos+15);
	// right
	do Screen.drawRectangle(xPos, yPos, xPos+3, yPos+15);
	// left
	do Screen.drawRectangle(xPos+13, yPos, xPos+15, yPos+15);
	return;
}

}