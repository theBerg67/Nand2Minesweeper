/** 
Program for drawing cells
Placement variables 
x- x coordinate
y- y coordinate
a - object type
yo - y offset 
Cell types
0 - Blank cell
1-8 - Number cells
9 - Bomb cell
10 - Flag cell
11 - Unopened cell
12 - Xed out cell (useful for game over)
*/

class cellDrawing {
field int x, y, a, yo;

// Cell placement function
constructor void place (int Ax, int Ay, int yOffset, int Object){
	let x = Ax;
	let y = Ay;
	let a = Object;
	let yo = yOffset;
	// Blank cell
	if (a = 0) {
		do blankCell(x,y,yo);
	}
	// Numbered cells
	if (a = 1) {
		do oneCell(x,y,yo);
	}
	if (a = 2) {
		do twoCell(x,y,yo);
	}
	if (a = 3) {
		do threeCell(x,y,yo);
	}
	if (a=4) {
		do fourCell(x,y,yo);
	}
	if (a=5) {
		do fiveCell(x,y,yo);
	}
	if (a=6) {
		do sixCell(x,y,yo);
	}
	if (a=7) {
		do sevenCell(x,y,yo);
	}
	if (a=8) {
		do eightCell(x,y,yo);
	}
	// Blow up a bomb
	if (a=9) {
		do blowupBomb(x,y,yo);
	}
	// Plant a flag
	if (a=10) {
		do plantFlag(x,y,yo);
	}
	// Unopened cell
	if (a=11) {
		do unopenedCell(x,y,yo);
	}
	if (a=12) {
		do xCell(x,y,yo);
	}
	return;
}

/** 
Area below for drawing all cells only
Big bitmap images after this
*/

// Blank cell
method void blankCell(int x,int y, int yo) {
	var int memAddress; 
	let memAddress = 16384+x+(y*512)+(yo*32);
	// column 0
	do Memory.poke(memAddress, -1);
	do Memory.poke(memAddress +32, -32767);
	do Memory.poke(memAddress +64, -32767);
	do Memory.poke(memAddress +96, -32767);
	do Memory.poke(memAddress +128, -32767);
	do Memory.poke(memAddress +160, -32767);
	do Memory.poke(memAddress +192, -32767);
	do Memory.poke(memAddress +224, -32767);
	do Memory.poke(memAddress +256, -32767);
	do Memory.poke(memAddress +288, -32767);
	do Memory.poke(memAddress +320, -32767);
	do Memory.poke(memAddress +352, -32767);
	do Memory.poke(memAddress +384, -32767);
	do Memory.poke(memAddress +416, -32767);
	do Memory.poke(memAddress +448, -32767);
	do Memory.poke(memAddress +480, -1);
	return;
}

